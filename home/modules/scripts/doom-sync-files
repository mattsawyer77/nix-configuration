#!/usr/bin/env zsh

set -Eeuo pipefail

doom_dir=~/.doom.d
rm -rf $doom_dir || :
mkdir -p $doom_dir
# remove any temporary compiled emacs files from repo
fd '\.elc' ~/workspaces/nix-configuration/home/modules/doom/emacs -x rm -v {}
rsync -av --delete --exclude "*-generated.el" ~/workspaces/nix-configuration/home/modules/doom/emacs/* $doom_dir
