#!/usr/bin/env zsh

set -Eeuo pipefail

doom_dir=~/.doom.d
rm -rf $doom_dir || :
mkdir -p $doom_dir
# remove any temporary compiled emacs files from repo
fd '\.elc' ~/workspaces/nix-configuration/home/modules/doom/emacs -x rm -v {}
rsync -av --delete ~/workspaces/nix-configuration/home/modules/doom/emacs/* $doom_dir
cp ~/.doom.d.nix/+nix-generated.el ~/.doom.d/+nix-generated.el
